#!/bin/bash
# pkglist-export — Export installed package list and sync to arch-native build server.
#
# Reads connection settings from /etc/arch-native-client.conf.
# Copy /usr/share/arch-native-client/arch-native-client.conf.example to
# /etc/arch-native-client.conf and fill in your values before use.

set -euo pipefail

CONFIG_FILE="/etc/arch-native-client.conf"

if [[ ! -f "$CONFIG_FILE" ]]; then
    logger -t pkglist-export "ERROR: $CONFIG_FILE not found — copy the example from /usr/share/arch-native-client/"
    echo "ERROR: $CONFIG_FILE not found." >&2
    echo "Copy /usr/share/arch-native-client/arch-native-client.conf.example to $CONFIG_FILE and configure it." >&2
    exit 1
fi

# shellcheck source=/dev/null
source "$CONFIG_FILE"

: "${REMOTE_HOST:?REMOTE_HOST not set in $CONFIG_FILE}"
: "${REMOTE_PATH:?REMOTE_PATH not set in $CONFIG_FILE}"

EXPORT_FILE=$(mktemp /tmp/pkglist-export-XXXXXX.json)
SSH_OPTS="-o StrictHostKeyChecking=accept-new"
if [[ -n "${SSH_KEY:-}" ]]; then
    SSH_OPTS="$SSH_OPTS -i $SSH_KEY"
fi

REMOTE="${REMOTE_HOST}:${REMOTE_PATH}"

# Build JSON manifest from pacman
pacman -Qi | python3 -c "
import sys, json, re, subprocess

# Get repo mapping from sync db
repo_map = {}
sl = subprocess.run(['pacman', '-Sl'], capture_output=True, text=True)
for line in sl.stdout.strip().split('\n'):
    parts = line.split()
    if len(parts) >= 2:
        repo_map[parts[1]] = parts[0]

# Parse -Qi for install info
text = sys.stdin.read()
packages = []
for block in text.strip().split('\n\n'):
    pkg = {}
    for line in block.split('\n'):
        m = re.match(r'^([\w ]+?)\s*:\s*(.+)', line)
        if m:
            pkg[m.group(1).strip()] = m.group(2).strip()
    if 'Name' in pkg:
        name = pkg['Name']
        packages.append({
            'name': name,
            'version': pkg.get('Version', ''),
            'repo': repo_map.get(name, 'unknown'),
            'reason': 'explicit' if 'Explicitly' in pkg.get('Install Reason', '') else 'dependency'
        })

print(json.dumps(packages, indent=2))
" > "$EXPORT_FILE"

PKG_COUNT=$(python3 -c "import json; print(len(json.load(open('$EXPORT_FILE'))))")

rsync -az --checksum -e "ssh ${SSH_OPTS}" "$EXPORT_FILE" "$REMOTE"

rm -f "$EXPORT_FILE"
logger -t pkglist-export "Synced $PKG_COUNT packages to $REMOTE_HOST"
exit 0
